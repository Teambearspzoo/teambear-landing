---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'TeamBear | Cyfryzacja + Automatyzacja',
  description = 'Digitalization and automation solutions combining BI, CRM, and custom web applications to streamline business processes.',
} = Astro.props;
---

<!doctype html>
<html lang="pl" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preload" as="image" href="/teambear-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&display=swap"
    />
    <script is:inline>
      document.documentElement.classList.remove('no-js');
    </script>
  </head>
  <body>
    <slot />
    <script>
      import { content, defaultLang, type Lang } from '../i18n';

      const els = document.querySelectorAll('.reveal');
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px 0px 0px' },
      );
      els.forEach((el) => io.observe(el));

      // Safety net: anything still hidden after load (e.g. short elements at the
      // very bottom of the page that can't scroll further into view) is revealed.
      window.addEventListener('load', () => {
        setTimeout(() => {
          document.querySelectorAll('.reveal:not(.is-visible)').forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight) {
              el.classList.add('is-visible');
              io.unobserve(el);
            }
          });
        }, 200);
      });

      // Language toggle: rewrites every [data-i18n] element's text from the
      // chosen locale in src/i18n.ts. Choice persists in localStorage.
      const STORAGE_KEY = 'teambear-lang';
      const TITLES: Record<Lang, string> = {
        pl: 'TeamBear | Cyfryzacja + Automatyzacja',
        en: 'TeamBear | Digitalization + Automation',
      };

      const resolve = (lang: Lang, path: string): string | undefined =>
        path.split('.').reduce<any>((acc, k) => (acc == null ? acc : acc[k]), content[lang]);

      function applyLang(lang: Lang) {
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const value = resolve(lang, el.dataset.i18n!);
          if (typeof value === 'string') el.textContent = value;
        });
        document.documentElement.lang = lang;
        document.title = TITLES[lang];

        document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((btn) => {
          const active = btn.dataset.lang === lang;
          btn.className =
            'px-3 py-1.5 text-sm font-medium rounded-md transition-all duration-300 ' +
            (active ? 'bg-[#FF5A2D] text-white' : 'text-white/60 hover:text-white');
        });

        try {
          localStorage.setItem(STORAGE_KEY, lang);
        } catch {}
      }

      let stored: string | null = null;
      try {
        stored = localStorage.getItem(STORAGE_KEY);
      } catch {}
      const initialLang: Lang = stored === 'en' || stored === 'pl' ? stored : defaultLang;
      if (initialLang !== defaultLang) applyLang(initialLang);

      document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((btn) => {
        btn.addEventListener('click', () => applyLang(btn.dataset.lang as Lang));
      });

      // Mobile menu toggle
      const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
      const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
      menu?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => menu.classList.add('hidden')),
      );
    </script>
  </body>
</html>
