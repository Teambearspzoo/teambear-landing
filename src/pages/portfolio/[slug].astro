---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Carousel from '../../components/Carousel.astro';
import { content } from '../../i18n';
import { projects } from '../../projects';
import { url } from '../../lib/url';

export function getStaticPaths() {
  return projects.map((meta, i) => ({
    params: { slug: meta.slug },
    props: { meta, index: i },
  }));
}

const { meta, index } = Astro.props;
const t = content.pl;
const project = t.portfolio.projects[index];
const pp = t.projectPage;
---

<Layout title={`TeamBear | ${project.title}`} description={project.desc}>
  <div class="min-h-screen overflow-x-hidden" style="background-color:#1a1a1a;font-family:'Instrument Sans', sans-serif">
    <Header />
    <main>
      <article class="relative bg-[#1a1a1a] pt-32 pb-24 overflow-hidden">
        <div class="absolute top-1/4 right-1/4 w-[min(600px,100vw)] h-[min(600px,100vw)] bg-[#FF5A2D]/10 rounded-full blur-[150px] pointer-events-none"></div>
        <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-12">
          <a href={url('/#portfolio')} class="reveal inline-flex items-center gap-2 text-sm text-white/50 hover:text-[#FF5A2D] transition-colors duration-300 mb-12">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true">
              <path d="m12 19-7-7 7-7"></path>
              <path d="M19 12H5"></path>
            </svg>
            <span data-i18n="projectPage.back">{pp.back}</span>
          </a>

          <div class="reveal">
            <span data-i18n="portfolio.category" class="text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-4 block">{t.portfolio.category}</span>
            <h1 data-i18n={`portfolio.projects.${index}.title`} class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-[1.1] tracking-tight mb-8">{project.title}</h1>
          </div>

          <div class="reveal mb-16">
            <Carousel images={meta.images} alt={project.title} />
          </div>

          <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">
            <div class="lg:col-span-2 reveal">
              <h2 data-i18n="projectPage.overview" class="text-sm font-medium tracking-[0.2em] uppercase text-[#FF5A2D] mb-4">{pp.overview}</h2>
              <p data-i18n={`portfolio.projects.${index}.desc`} class="text-white/60 text-lg leading-relaxed mb-12">{project.desc}</p>

              <h2 data-i18n="projectPage.whatWeDid" class="text-sm font-medium tracking-[0.2em] uppercase text-[#FF5A2D] mb-6">{pp.whatWeDid}</h2>
              <ul class="space-y-4">
                {
                  project.highlights.map((h, j) => (
                    <li class="flex items-start gap-4">
                      <span class="mt-1 w-5 h-5 rounded-full bg-[#FF5A2D]/15 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-[#FF5A2D]" aria-hidden="true">
                          <path d="M20 6 9 17l-5-5" />
                        </svg>
                      </span>
                      <span data-i18n={`portfolio.projects.${index}.highlights.${j}`} class="text-white/60 leading-relaxed">
                        {h}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <aside class="reveal">
              <div class="p-8 rounded-2xl bg-white/[0.02] border border-white/5 sticky top-32">
                <h2 data-i18n="projectPage.technologies" class="text-sm font-medium tracking-[0.2em] uppercase text-[#FF5A2D] mb-6">{pp.technologies}</h2>
                <div class="flex flex-wrap gap-2">
                  {
                    meta.tags.map((tag) => (
                      <span class="px-3 py-1 text-xs font-medium text-white/50 bg-white/5 rounded-full border border-white/10">{tag}</span>
                    ))
                  }
                </div>
              </div>
            </aside>
          </div>
        </div>
      </article>

      <section class="bg-[#141414] py-24 relative overflow-hidden">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[min(800px,100vw)] h-[min(400px,50vw)] bg-[#FF5A2D]/5 rounded-full blur-[150px] pointer-events-none"></div>
        <div class="reveal relative z-10 max-w-3xl mx-auto px-6 lg:px-12 text-center">
          <h2 data-i18n="projectPage.ctaTitle" class="text-3xl md:text-4xl font-bold text-white mb-4">{pp.ctaTitle}</h2>
          <p data-i18n="projectPage.ctaLead" class="text-white/50 text-lg leading-relaxed mb-8">{pp.ctaLead}</p>
          <a href={url('/#kontakt')} data-i18n="projectPage.ctaButton" class="inline-flex items-center justify-center px-8 py-4 bg-[#FF5A2D] text-white font-medium rounded-lg hover:bg-[#FF5A2D]/90 transition-all duration-300 hover:translate-y-[-2px]">{pp.ctaButton}</a>
        </div>
      </section>
    </main>
    <Footer />
  </div>
</Layout>
