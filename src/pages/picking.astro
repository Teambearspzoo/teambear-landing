---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Subheader from '../components/picking/Subheader.astro';
import Hero from '../components/picking/Hero.astro';
import Problem from '../components/picking/Problem.astro';
import Target from '../components/picking/Target.astro';
import Offer from '../components/picking/Offer.astro';
import Process from '../components/picking/Process.astro';
import Usp from '../components/picking/Usp.astro';
import CaseStudy from '../components/picking/CaseStudy.astro';
import Icp from '../components/picking/Icp.astro';
import Faq from '../components/picking/Faq.astro';
import Contact from '../components/picking/Contact.astro';
import Footer from '../components/picking/Footer.astro';

const title = 'System obsługi zamówień z pickingiem dla firm handlowych | TeamBear';
const description =
  'Wdrażamy systemy obsługi zamówień z kolektorami dla rosnących polskich firm handlowych. Integracja z Twoim ERP i sklepem. On-prem. 3 miesiące do go-live.';
---

<Layout title={title} description={description}>
  <div class="min-h-screen overflow-x-hidden" style="background-color:#1a1a1a;font-family:'Instrument Sans', sans-serif">
    <Header />
    <Subheader />
    <main>
      <Hero />
      <Problem />
      <Target />
      <Offer />
      <Process />
      <Usp />
      <CaseStudy />
      <Icp />
      <Faq />
      <Contact />
    </main>
    <Footer />
  </div>
</Layout>
