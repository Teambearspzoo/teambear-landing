---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Icon from '../components/Icon.astro';

const title = 'System obsługi zamówień z pickingiem dla firm handlowych | TeamBear';
const description =
  'Wdrażamy systemy obsługi zamówień z kolektorami dla rosnących polskich firm handlowych. Integracja z Twoim ERP i sklepem. On-prem. 3 miesiące do go-live.';

const mailtoMain = `mailto:piotr.zaworski@teambear.io?subject=${encodeURIComponent('Bezpłatna analiza procesu - obsługa zamówień')}`;
const mailtoPdf = `mailto:piotr.zaworski@teambear.io?subject=${encodeURIComponent('Proszę o one-pager PDF - system pickingowy')}`;

const navLinks = [
  { href: '#problem', label: 'Problem' },
  { href: '#co-dostajesz', label: 'Co dostajesz' },
  { href: '#proces', label: 'Wdrożenie' },
  { href: '#faq', label: 'FAQ' },
];

const problems = [
  {
    icon: 'fileText',
    title: 'Zamówienia drukowane na kartce',
    desc: 'Magazynier bierze listę, biega po magazynie w przypadkowej kolejności, zaznacza długopisem co wziął.',
  },
  {
    icon: 'clock',
    title: 'Picking trwa godzinami zamiast minutami',
    desc: 'Bo towar leży zupełnie inaczej, niż klient zamówił.',
  },
  {
    icon: 'penLine',
    title: 'Osoba w biurze przepisuje WZ-tki ręcznie',
    desc: 'Do Subiekta / Comarcha / Symfonii. Grupuje, kalkuluje, wbija pozycję po pozycji.',
  },
  {
    icon: 'alertTriangle',
    title: 'Reklamacji przybywa',
    desc: 'Zła pozycja, zła ilość, pomyłka w sezonie.',
  },
  {
    icon: 'trendingUp',
    title: 'Sprzedaż mogłaby rosnąć szybciej',
    desc: 'Tylko magazyn już nie wyrabia.',
  },
];

const workflow = [
  { tone: 'accent', icon: 'smartphone', title: 'Magazynier', body: 'Kolektor pokazuje listę. Skanuje, wpisuje ilość, idzie dalej.' },
  { tone: 'muted', icon: 'scanLine', title: 'Ścieżka', body: 'System wyznacza najkrótszą trasę po regałach.' },
  { tone: 'muted', icon: 'monitor', title: 'Biuro', body: 'Portal webowy. Widać kto co kompletuje, w czasie rzeczywistym.' },
  { tone: 'accent', icon: 'link', title: 'ERP', body: 'WZ / faktura ląduje w Twoim systemie. Bez przepisywania.' },
];

const offer = [
  {
    icon: 'smartphone',
    label: 'Aplikacja',
    title: 'Aplikacja na kolektor',
    body: 'Autorska aplikacja - picking, zmiana statusu zamówienia, przypisywanie do magazynierów. Cztery ekrany. Magazynier ogarnia ją w jeden dzień.',
  },
  {
    icon: 'monitor',
    label: 'Portal',
    title: 'Portal webowy',
    body: 'Zarządzanie zamówieniami i produktami. Konfiguracja ścieżki pickingowej (regał / półka / slot). Role dla admina, biura, magazyniera.',
  },
  {
    icon: 'scanLine',
    label: 'Hardware',
    title: 'Kolektory w pakiecie',
    body: 'Dostarczamy gotowe do pracy. Rozpakowujesz, ładujesz, picking startuje. Bez kombinowania z MDM, konfiguracjami, dostawcami sprzętu.',
  },
  {
    icon: 'plug',
    label: 'Integracja',
    title: 'Integracja z Twoimi systemami',
    body: 'Łączymy z Twoim ERP / systemem księgowym i Twoim sklepem e-commerce. Zakres integracji ustalamy w trakcie analizy procesu.',
  },
];

const steps = [
  { icon: 'messageSquare', title: 'Bezpłatna analiza procesu', meta: '40 min · online', body: 'Zaczynamy od rozmowy. Pokazujesz, jak wygląda obsługa zamówień dziś. Mówimy szczerze, czy nasz system ma sens w Twoim przypadku.' },
  { icon: 'mapPin', title: 'Wizyta u Ciebie', meta: '3 dni · on-site', body: 'Konsultant przyjeżdża do magazynu. Mapujemy proces, projektujemy ścieżkę pickingową, ustalamy zakres integracji.' },
  { icon: 'settings', title: 'Konfiguracja systemu', meta: 'Tydzień 2-6', body: 'Konfigurujemy portal i aplikację pod Twój układ magazynu i Twoje procesy.' },
  { icon: 'link', title: 'Integracje', meta: 'Tydzień 4-9', body: 'Łączymy z Twoim ERP / systemem księgowym i sklepem e-commerce.' },
  { icon: 'truck', title: 'Dostawa kolektorów + szkolenie', meta: 'Tydzień 10-11', body: 'Sprzęt przyjeżdża skonfigurowany. Szkolimy magazyn i biuro. Idziemy live.' },
  { icon: 'headset', title: '3 miesiące supportu w cenie', meta: 'Po go-live', body: 'Jesteśmy dostępni od pierwszego dnia. Reagujemy na bieżąco, dostrajamy proces.' },
];

const usps = [
  { icon: 'target', title: 'Robimy jedną rzecz', body: 'Nie sprzedajemy „wszystkiego” - pełnego WMS, ERP, e-commerce. Picking i obsługa zamówień. Tu jesteśmy konkretni i szybcy.' },
  { icon: 'package', title: 'Kolektor w pakiecie', body: 'Większość rozwiązań to czysty software - „kup sobie sprzęt sam”. My przywozimy gotowe urządzenia. Włączasz i pracujesz.' },
  { icon: 'shield', title: 'On-prem na Twoim serwerze', body: 'Standardowo wdrażamy lokalnie. Twoje dane zostają u Ciebie. Nie blokujemy Cię chmurą. Hosting po naszej stronie też możliwy - wybór jest Twój.' },
];

const metrics = [
  { big: '2×', unit: 'szybciej', body: 'Tyle skrócił się czas obsługi zamówienia', placeholder: false },
  { big: '3', unit: 'miesiące', body: 'Od podpisania umowy do go-live', placeholder: false },
  { big: '25 h', unit: '/ tydzień', body: 'Tyle godzin biuro przestało spędzać na ręcznym wbijaniu WZ-tek', placeholder: false },
  { big: '35%', unit: 'mniej', body: 'Spadek liczby reklamacji z powodu błędów magazynu', placeholder: false },
];

const caseTags = ['Subiekt GT', 'Sklep e-commerce', '5 kolektorów', 'On-prem'];

const icpFor = [
  'Masz własny magazyn (nie korzystasz z fulfillmentu)',
  'Obracasz ponad 100 SKU',
  'Realizujesz co najmniej 10 zamówień dziennie',
  'Średnie zamówienie ma więcej niż jedną-dwie pozycje',
  'Czas obsługi zamówień zaczyna ograniczać wzrost firmy',
  'Masz już ERP / system księgowy, do którego chcesz to spiąć',
];
const icpNot = [
  'Wysyłasz mniej niż 10 zamówień dziennie (zwrot z inwestycji nie nadąża)',
  'Korzystasz z 3PL / fulfillmentu - nie masz własnego magazynu do optymalizacji',
  'Szukasz pełnego WMS-u z inwentaryzacją, awizacjami, multi-warehouse',
  'Chcesz gotowca SaaS w 200 zł/mc - to nie ten segment',
];

const faqs = [
  { q: 'Ile to kosztuje?', a: 'Wdrożenie typowo 80 000 - 150 000 PLN netto (jednorazowo, w cenie hardware). Maintenance 2 000 - 5 000 PLN/mc w zależności od SLA. Konkretną wycenę przygotowujemy po analizie procesu.' },
  { q: 'Ile trwa wdrożenie?', a: 'Około 3 miesięcy od podpisania umowy do uruchomienia na produkcji. Bez burzenia bieżącej pracy.' },
  { q: 'Czy moi pracownicy ogarną kolektor?', a: 'Aplikacja ma cztery ekrany. Magazynierzy uczą się jej w jeden dzień. Nie wymagamy znajomości technologii.' },
  { q: 'Z jakimi systemami się integrujecie?', a: 'Zaczynaliśmy od Subiekta GT i sklepu opartego o Medusę. Każdy kolejny system (Comarch, Symfonia, enova, WooCommerce, Shoper, IdoSell, Magento etc.) wymaga osobnego rozpoznania - robimy to bezpłatnie w trakcie analizy.' },
  { q: 'Czy moje dane będą bezpieczne?', a: 'Standardowo wdrażamy on-prem - system działa na Twoim serwerze, dane nigdy nie opuszczają Twojej infrastruktury. Możemy też hostować po naszej stronie, jeśli wolisz.' },
  { q: 'Co, jeśli za rok zechcę rozszerzyć system?', a: 'Kod jest Twój, dokumentacja Twoja. Możemy rozszerzać razem - albo każdy inny zespół developerski może podjąć się rozwoju. Bez vendor locka.' },
  { q: 'Czy macie referencje?', a: 'Tak. Pierwsza firma wdrożeniowa zgodziła się na rozmowę telefoniczną z zakwalifikowanymi prospektami. Dane przekazujemy na zaawansowanym etapie rozmów.' },
];

const ctaPoints = [
  'Mapujemy Twój obecny proces obsługi zamówień',
  'Mówimy szczerze, czy nasz system ma sens u Ciebie',
  'Szacujemy, ile czasu i błędów realnie zaoszczędzisz',
];
---

<Layout title={title} description={description}>
  <div class="min-h-screen overflow-x-hidden" style="background-color:#1a1a1a;font-family:'Instrument Sans', sans-serif">
    <Header />

    <!-- Subheader: nawigacja sekcyjna tej strony -->
    <div class="fixed top-[72px] left-0 right-0 z-40 bg-[#1a1a1a]/85 backdrop-blur-sm border-b border-white/5">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <nav class="flex items-center gap-6 md:gap-8 h-12 overflow-x-auto text-sm">
          <span class="hidden sm:inline shrink-0 text-[#FF5A2D] text-xs font-medium tracking-[0.2em] uppercase">//Picking</span>
          {
            navLinks.map((l) => (
              <a href={l.href} class="shrink-0 whitespace-nowrap text-white/60 hover:text-white transition-colors duration-300">
                {l.label}
              </a>
            ))
          }
          <a href="#kontakt" class="ml-auto shrink-0 whitespace-nowrap text-[#FF5A2D] hover:text-[#FF5A2D]/80 font-medium transition-colors duration-300">Kontakt</a>
        </nav>
      </div>
    </div>

    <main>
      <!-- SEKCJA: HERO -->
      <section class="relative min-h-screen flex items-center bg-[#1a1a1a] overflow-hidden">
        <div
          class="absolute inset-0 opacity-[0.03]"
          style="background-image:linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px);background-size:60px 60px"
        >
        </div>
        <div class="absolute top-1/3 right-[10%] w-[min(700px,100vw)] h-[min(700px,100vw)] bg-[#FF5A2D]/10 rounded-full blur-[150px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-[min(500px,100vw)] h-[min(500px,100vw)] bg-[#FF5A2D]/5 rounded-full blur-[150px] pointer-events-none"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-44 pb-24 w-full">
          <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
            <div class="lg:col-span-7">
              <div class="reveal">
                <span class="text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase">//Picking dla firm handlowych</span>
              </div>
              <h1 class="reveal text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.05] tracking-tight mt-4 mb-8" style="transition-delay:80ms">
                Twoja sprzedaż rośnie.<br />
                <span class="text-white/40">Magazyn nie nadąża.</span>
              </h1>
              <p class="reveal text-lg md:text-xl text-white/60 max-w-2xl mb-10 leading-relaxed" style="transition-delay:160ms">
                Wdrażamy system obsługi zamówień z kolektorami dla polskich firm handlowych. Picking po zoptymalizowanej ścieżce, automatyczne WZ-tki w Twoim ERP, integracja z Twoim sklepem.
              </p>

              <div class="reveal flex flex-wrap gap-x-8 gap-y-3 mb-10" style="transition-delay:220ms">
                {
                  ['Wdrożenie w 3 miesiące', 'On-prem na Twoim serwerze', 'Kolektory w pakiecie'].map((fact) => (
                    <div class="flex items-center gap-2">
                      <Icon name="check" class="w-4 h-4 text-[#FF5A2D]" strokeWidth={2.4} />
                      <span class="text-white/70 text-sm">{fact}</span>
                    </div>
                  ))
                }
              </div>

              <div class="reveal flex flex-col sm:flex-row gap-4" style="transition-delay:300ms">
                <a href={mailtoMain} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5A2D] text-white font-medium rounded-lg hover:bg-[#FF5A2D]/90 transition-all duration-300 hover:-translate-y-[2px]">
                  Umów bezpłatną analizę procesu
                  <Icon name="arrowRight" class="w-4 h-4" />
                </a>
                <a href={mailtoPdf} class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-medium rounded-lg hover:bg-white/5 transition-all duration-300">
                  Poproś o one-pager (PDF)
                  <Icon name="download" class="w-4 h-4" />
                </a>
              </div>

              <p class="reveal text-white/40 text-sm mt-6" style="transition-delay:360ms">
                Bez prezentacji. 40 minut z konsultantem, który zna magazyn.
              </p>
            </div>

            <div class="reveal lg:col-span-5" style="transition-delay:200ms">
              <!-- Stylizowany kolektor z ekranem aplikacji pickingowej -->
              <div class="relative w-full max-w-[420px] mx-auto">
                <div class="reveal absolute -top-4 -left-8 z-20">
                  <div class="px-3 py-2 rounded-lg bg-[#141414] border border-white/10 flex items-center gap-2 shadow-[0_0_0_1px_rgba(255,255,255,0.02)]">
                    <span class="w-2 h-2 rounded-full bg-[#FF5A2D] animate-pulse"></span>
                    <span class="text-white/70 text-xs font-medium tracking-wide">Picking aktywny</span>
                  </div>
                </div>
                <div class="reveal absolute -bottom-6 -right-6 z-20" style="transition-delay:200ms">
                  <div class="px-3 py-2 rounded-lg bg-[#141414] border border-white/10 flex items-center gap-2">
                    <Icon name="check" class="w-3.5 h-3.5 text-[#FF5A2D]" />
                    <span class="text-white/70 text-xs font-medium tracking-wide">WZ wystawiona</span>
                  </div>
                </div>

                <div class="relative rounded-[36px] bg-gradient-to-b from-[#222] to-[#0e0e0e] border border-white/10 p-3 shadow-[0_30px_80px_-20px_rgba(0,0,0,0.8)]">
                  <div class="flex items-center justify-between px-4 pt-1 pb-3">
                    <span class="text-[10px] text-white/30 tracking-[0.25em] uppercase">TeamBear</span>
                    <div class="flex items-center gap-1">
                      <span class="w-1 h-1 rounded-full bg-white/30"></span>
                      <span class="w-6 h-1 rounded-full bg-white/15"></span>
                    </div>
                  </div>

                  <div class="relative rounded-[20px] bg-[#0a0a0a] overflow-hidden border border-white/[0.06]">
                    <div class="flex items-center justify-between px-4 py-2 text-[10px] text-white/40 border-b border-white/5">
                      <span>09:24</span>
                      <div class="flex items-center gap-2">
                        <span>Wi-Fi</span>
                        <span>87%</span>
                      </div>
                    </div>

                    <div class="px-4 pt-4 pb-3">
                      <div class="flex items-center justify-between mb-3">
                        <span class="text-[10px] text-[#FF5A2D] tracking-[0.2em] uppercase font-medium">Zamówienie</span>
                        <span class="text-[10px] text-white/30">3 / 7</span>
                      </div>
                      <div class="text-white text-lg font-semibold leading-tight">#ZK-2034</div>
                      <div class="text-white/40 text-xs mt-1">Sklep online · Klient: P. Nowak</div>
                    </div>

                    <div class="mx-3 mb-2 rounded-xl bg-[#FF5A2D]/10 border border-[#FF5A2D]/30 p-3">
                      <div class="flex items-start justify-between gap-3 mb-2">
                        <div>
                          <div class="text-[9px] text-[#FF5A2D] uppercase tracking-[0.2em] font-medium">Regał A · Półka 03</div>
                          <div class="text-white text-sm font-semibold mt-1">Filtr olejowy HX-204</div>
                        </div>
                        <div class="shrink-0 w-8 h-8 rounded-md bg-[#FF5A2D] flex items-center justify-center">
                          <Icon name="scanLine" class="w-4 h-4 text-white" strokeWidth={2.4} />
                        </div>
                      </div>
                      <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                          <span class="text-white/60 text-[10px]">Ilość</span>
                          <span class="px-2 py-0.5 rounded bg-white/10 text-white text-xs font-semibold">2 / 2</span>
                        </div>
                        <Icon name="barcode" class="w-10 h-4 text-white/40" strokeWidth={1.6} />
                      </div>
                    </div>

                    <div class="mx-3 mb-2 rounded-xl bg-white/[0.02] border border-white/5 p-3 flex items-center justify-between">
                      <div>
                        <div class="text-[9px] text-white/30 uppercase tracking-[0.2em]">B · 12</div>
                        <div class="text-white/50 text-xs font-medium line-through mt-0.5">Klocki hamulcowe</div>
                      </div>
                      <div class="w-6 h-6 rounded-full bg-white/5 flex items-center justify-center">
                        <Icon name="check" class="w-3.5 h-3.5 text-white/50" strokeWidth={2.4} />
                      </div>
                    </div>

                    <div class="mx-3 mb-3 rounded-xl bg-white/[0.02] border border-white/5 p-3 flex items-center justify-between">
                      <div>
                        <div class="text-[9px] text-white/30 uppercase tracking-[0.2em]">C · 04</div>
                        <div class="text-white/50 text-xs font-medium line-through mt-0.5">Pasek rozrządu</div>
                      </div>
                      <div class="w-6 h-6 rounded-full bg-white/5 flex items-center justify-center">
                        <Icon name="check" class="w-3.5 h-3.5 text-white/50" strokeWidth={2.4} />
                      </div>
                    </div>

                    <div class="mx-3 mb-3 px-3 py-2 rounded-lg bg-white/[0.03] border border-white/5 flex items-center justify-between">
                      <span class="text-[10px] text-white/40 uppercase tracking-[0.15em]">Ścieżka</span>
                      <div class="flex items-center gap-1">
                        <span class="text-[10px] text-white/50">C</span>
                        <Icon name="arrowRight" class="w-2.5 h-2.5 text-white/30" />
                        <span class="text-[10px] text-white/50">B</span>
                        <Icon name="arrowRight" class="w-2.5 h-2.5 text-white/30" />
                        <span class="text-[10px] text-[#FF5A2D] font-semibold">A</span>
                        <Icon name="arrowRight" class="w-2.5 h-2.5 text-white/30" />
                        <span class="text-[10px] text-white/30">D</span>
                        <Icon name="arrowRight" class="w-2.5 h-2.5 text-white/30" />
                        <span class="text-[10px] text-white/30">F</span>
                      </div>
                    </div>

                    <div class="px-3 pb-4">
                      <div class="w-full py-3 rounded-xl bg-[#FF5A2D] text-white text-xs font-semibold text-center tracking-wide">
                        Zakończ kompletację
                      </div>
                    </div>

                    <div class="flex items-center justify-center pb-2">
                      <span class="w-16 h-1 rounded-full bg-white/15"></span>
                    </div>
                  </div>

                  <div class="flex items-center justify-center gap-3 pt-3 pb-1">
                    <span class="w-12 h-1.5 rounded-full bg-white/10"></span>
                    <span class="w-3 h-3 rounded-full border border-white/15"></span>
                  </div>
                </div>

                <div class="absolute top-1/2 -translate-y-1/2 -right-2 w-1.5 h-16 rounded-full bg-white/5"></div>
                <div class="absolute top-1/3 -left-2 w-1.5 h-10 rounded-full bg-white/5"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="absolute bottom-0 left-0 right-0 border-t border-white/5 bg-[#1a1a1a]/80 backdrop-blur-sm">
          <div class="max-w-7xl mx-auto px-6 lg:px-12 py-4 flex flex-wrap items-center justify-center md:justify-between gap-4 text-center md:text-left">
            <span class="text-white/30 text-xs tracking-[0.2em] uppercase">Pierwsze wdrożenie zrealizowane</span>
            <span class="text-white/20 text-xs hidden md:inline">·</span>
            <span class="text-white/30 text-xs tracking-[0.2em] uppercase">Polski software house</span>
            <span class="text-white/20 text-xs hidden md:inline">·</span>
            <span class="text-white/30 text-xs tracking-[0.2em] uppercase">On-prem lub chmura</span>
            <span class="text-white/20 text-xs hidden md:inline">·</span>
            <span class="text-white/30 text-xs tracking-[0.2em] uppercase">Subiekt · Comarch · WooCommerce</span>
          </div>
        </div>
      </section>

      <!-- SEKCJA 01: PROBLEM -->
      <section id="problem" class="bg-[#141414] py-32 relative overflow-hidden scroll-mt-[136px]">
        <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
          <div class="grid lg:grid-cols-12 gap-16 lg:gap-24 mb-16">
            <div class="lg:col-span-5">
              <div class="reveal lg:sticky lg:top-32">
                <span class="block text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-4">//01 Problem</span>
                <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
                  Rozpoznajesz się<br /><span class="text-white/40">w tym?</span>
                </h2>
                <p class="text-white/50 text-lg leading-relaxed max-w-md">
                  Pięć bolączek, które słyszymy w prawie każdym magazynie, do którego wchodzimy.
                </p>
              </div>
            </div>
            <div class="lg:col-span-7">
              <div class="space-y-4">
                {
                  problems.map((p, i) => (
                    <div class="reveal group p-6 md:p-8 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[#FF5A2D]/20 hover:bg-white/[0.04] transition-all duration-500" style={`transition-delay:${i * 60}ms`}>
                      <div class="flex items-start gap-5">
                        <div class="shrink-0 w-12 h-12 rounded-xl bg-[#FF5A2D]/10 flex items-center justify-center group-hover:bg-[#FF5A2D]/20 transition-colors duration-300">
                          <Icon name={p.icon} class="w-5 h-5 text-[#FF5A2D]" />
                        </div>
                        <div class="flex-1 min-w-0">
                          <h3 class="text-lg md:text-xl font-semibold text-white mb-2 group-hover:text-[#FF5A2D] transition-colors duration-300">{p.title}</h3>
