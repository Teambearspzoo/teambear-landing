---
import { content } from '../i18n';
import { url } from '../lib/url';
const t = content.pl.footer;
---

<footer class="bg-[#1a1a1a] border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
    <div class="reveal flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <img src={url('/teambear-logo.png')} alt="TeamBear" class="h-6 opacity-60 hover:opacity-100 transition-opacity" />
      </div>
      <div class="text-center md:text-right">
        <p data-i18n="footer.copyright" class="text-white/40 text-sm">{t.copyright}</p>
        <p data-i18n="footer.tagline" class="text-white/30 text-xs mt-1">{t.tagline}</p>
      </div>
    </div>
  </div>
</footer>
