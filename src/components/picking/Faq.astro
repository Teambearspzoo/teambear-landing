---
import Icon from '../Icon.astro';
import { content } from '../../i18n';
import { mailtoMain } from './links';

const t = content.pl.picking;
---

<!-- SEKCJA 08: FAQ -->
<section id="faq" class="bg-[#1a1a1a] py-32 relative overflow-hidden scroll-mt-[136px]">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
    <div class="grid lg:grid-cols-12 gap-16">
      <div class="lg:col-span-4">
        <div class="reveal lg:sticky lg:top-32">
          <span data-i18n="picking.faq.eyebrow" class="block text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-4">{t.faq.eyebrow}</span>
          <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
            <span data-i18n="picking.faq.title1">{t.faq.title1}</span><br /><span data-i18n="picking.faq.title2" class="text-white/40">{t.faq.title2}</span>
          </h2>
          <p data-i18n="picking.faq.side" class="text-white/50 leading-relaxed mb-8">
            {t.faq.side}
          </p>
          <a href={mailtoMain} class="group inline-flex items-center gap-2 text-[#FF5A2D] font-medium transition-all duration-300">
            <span data-i18n="picking.faq.cta">{t.faq.cta}</span>
            <Icon name="arrowRight" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" />
          </a>
        </div>
      </div>
      <div class="lg:col-span-8">
        <div>
          {
            t.faq.items.map((f, i) => (
              <details class="reveal group border-t border-white/5" open={i === 0}>
                <summary class="w-full py-6 md:py-7 flex items-center justify-between gap-6 text-left cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
                  <span data-i18n={`picking.faq.items.${i}.q`} class="text-lg md:text-xl font-medium text-white group-hover:text-[#FF5A2D] group-open:text-[#FF5A2D] transition-colors duration-300">
                    {f.q}
                  </span>
                  <span class="shrink-0 w-10 h-10 rounded-full border border-white/10 bg-white/[0.02] group-hover:border-[#FF5A2D]/30 group-open:border-[#FF5A2D]/40 group-open:bg-[#FF5A2D]/10 group-open:rotate-45 flex items-center justify-center transition-all duration-300">
                    <Icon name="plus" class="w-4 h-4 text-white/70 group-open:text-[#FF5A2D]" strokeWidth={2.2} />
                  </span>
                </summary>
                <p data-i18n={`picking.faq.items.${i}.a`} class="pb-7 pr-16 text-white/55 leading-relaxed max-w-3xl">{f.a}</p>
              </details>
            ))
          }
          <div class="border-t border-white/5"></div>
        </div>
      </div>
    </div>
  </div>
</section>
