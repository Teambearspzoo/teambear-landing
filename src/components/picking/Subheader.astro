---
import { content } from '../../i18n';

const t = content.pl.picking;

const navLinks = [
  { href: '#problem', key: 'problem', label: t.nav.problem },
  { href: '#co-dostajesz', key: 'offer', label: t.nav.offer },
  { href: '#proces', key: 'proces', label: t.nav.proces },
  { href: '#faq', key: 'faq', label: t.nav.faq },
];
---

<!-- Subheader: nawigacja sekcyjna tej strony -->
<div class="fixed top-[72px] left-0 right-0 z-40 bg-[#1a1a1a]/85 backdrop-blur-sm border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <nav class="flex items-center gap-6 md:gap-8 h-12 overflow-x-auto text-sm">
      <span data-i18n="picking.nav.badge" class="hidden sm:inline shrink-0 text-[#FF5A2D] text-xs font-medium tracking-[0.2em] uppercase">{t.nav.badge}</span>
      {
        navLinks.map((l) => (
          <a href={l.href} data-i18n={`picking.nav.${l.key}`} class="shrink-0 whitespace-nowrap text-white/60 hover:text-white transition-colors duration-300">
            {l.label}
          </a>
        ))
      }
      <a href="#kontakt" data-i18n="picking.nav.kontakt" class="ml-auto shrink-0 whitespace-nowrap text-[#FF5A2D] hover:text-[#FF5A2D]/80 font-medium transition-colors duration-300">{t.nav.kontakt}</a>
    </nav>
  </div>
</div>
