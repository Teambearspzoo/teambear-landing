---
import Icon from '../Icon.astro';
import { content } from '../../i18n';

const t = content.pl.picking;
const problemIcons = ['fileText', 'clock', 'penLine', 'alertTriangle', 'trendingUp'];
---

<!-- SEKCJA 01: PROBLEM -->
<section id="problem" class="bg-[#141414] py-32 relative overflow-hidden scroll-mt-[136px]">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
    <div class="grid lg:grid-cols-12 gap-16 lg:gap-24 mb-16">
      <div class="lg:col-span-5">
        <div class="reveal lg:sticky lg:top-32">
          <span data-i18n="picking.problem.eyebrow" class="block text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-4">{t.problem.eyebrow}</span>
          <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
            <span data-i18n="picking.problem.title1">{t.problem.title1}</span><br /><span data-i18n="picking.problem.title2" class="text-white/40">{t.problem.title2}</span>
          </h2>
          <p data-i18n="picking.problem.lead" class="text-white/50 text-lg leading-relaxed max-w-md">
            {t.problem.lead}
          </p>
        </div>
      </div>
      <div class="lg:col-span-7">
        <div class="space-y-4">
          {
            t.problem.items.map((p, i) => (
              <div class="reveal group p-6 md:p-8 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[#FF5A2D]/20 hover:bg-white/[0.04] transition-all duration-500" style={`transition-delay:${i * 60}ms`}>
                <div class="flex items-start gap-5">
                  <div class="shrink-0 w-12 h-12 rounded-xl bg-[#FF5A2D]/10 flex items-center justify-center group-hover:bg-[#FF5A2D]/20 transition-colors duration-300">
                    <Icon name={problemIcons[i]} class="w-5 h-5 text-[#FF5A2D]" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 data-i18n={`picking.problem.items.${i}.title`} class="text-lg md:text-xl font-semibold text-white mb-2 group-hover:text-[#FF5A2D] transition-colors duration-300">{p.title}</h3>
                    <p data-i18n={`picking.problem.items.${i}.desc`} class="text-white/50 leading-relaxed">{p.desc}</p>
                  </div>
                  <span class="hidden md:block text-white/20 text-sm font-medium mt-1">0{i + 1}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="reveal max-w-3xl mx-auto text-center pt-8 border-t border-white/5">
      <p data-i18n="picking.problem.closing" class="text-white/40 text-base md:text-lg leading-relaxed">
        {t.problem.closing}
      </p>
    </div>
  </div>
</section>
