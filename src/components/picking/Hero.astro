---
import Icon from '../Icon.astro';
import { content } from '../../i18n';
import { mailtoMain } from './links';

const t = content.pl.picking;
---

<!-- SEKCJA: HERO -->
<section class="relative min-h-screen flex items-center bg-[#1a1a1a] overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image:linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px);background-size:60px 60px"
  >
  </div>
  <div class="absolute top-1/3 right-[10%] w-[min(700px,100vw)] h-[min(700px,100vw)] bg-[#FF5A2D]/10 rounded-full blur-[150px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[min(500px,100vw)] h-[min(500px,100vw)] bg-[#FF5A2D]/5 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-44 pb-24 w-full">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7">
        <div class="reveal">
          <span data-i18n="picking.hero.eyebrow" class="text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase">{t.hero.eyebrow}</span>
        </div>
        <h1 class="reveal text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.05] tracking-tight mt-4 mb-8" style="transition-delay:80ms">
          <span data-i18n="picking.hero.title1">{t.hero.title1}</span><br />
          <span data-i18n="picking.hero.title2" class="text-white/40">{t.hero.title2}</span>
        </h1>
        <p data-i18n="picking.hero.lead" class="reveal text-lg md:text-xl text-white/60 max-w-2xl mb-10 leading-relaxed" style="transition-delay:160ms">
          {t.hero.lead}
        </p>

        <div class="reveal flex flex-wrap gap-x-8 gap-y-3 mb-10" style="transition-delay:220ms">
          {
            t.hero.facts.map((fact, i) => (
              <div class="flex items-center gap-2">
                <Icon name="check" class="w-4 h-4 text-[#FF5A2D]" strokeWidth={2.4} />
                <span data-i18n={`picking.hero.facts.${i}`} class="text-white/70 text-sm">{fact}</span>
              </div>
            ))
          }
        </div>

        <div class="reveal flex flex-col sm:flex-row gap-4" style="transition-delay:300ms">
          <a href={mailtoMain} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5A2D] text-white font-medium rounded-lg hover:bg-[#FF5A2D]/90 transition-all duration-300 hover:-translate-y-[2px]">
            <span data-i18n="picking.hero.cta1">{t.hero.cta1}</span>
            <Icon name="arrowRight" class="w-4 h-4" />
          </a>
          <a href="/teambear-picking-onepager.pdf" download="TeamBear-picking-one-pager.pdf" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-medium rounded-lg hover:bg-white/5 transition-all duration-300">
            <span data-i18n="picking.hero.cta2">{t.hero.cta2}</span>
            <Icon name="download" class="w-4 h-4" />
          </a>
        </div>

        <p data-i18n="picking.hero.note" class="reveal text-white/40 text-sm mt-6" style="transition-delay:360ms">
          {t.hero.note}
        </p>
      </div>

      <div class="reveal lg:col-span-5" style="transition-delay:200ms">
        <!-- Stylizowany kolektor z ekranem aplikacji pickingowej -->
        <div class="relative w-full max-w-[420px] mx-auto">
          <div class="reveal absolute -top-4 -left-8 z-20">
            <div class="px-3 py-2 rounded-lg bg-[#141414] border border-white/10 flex items-center gap-2 shadow-[0_0_0_1px_rgba(255,255,255,0.02)]">
              <span class="w-2 h-2 rounded-full bg-[#FF5A2D] animate-pulse"></span>
              <span data-i18n="picking.mock.active" class="text-white/70 text-xs font-medium tracking-wide">{t.mock.active}</span>
            </div>
          </div>
          <div class="reveal absolute -bottom-6 -right-6 z-20" style="transition-delay:200ms">
            <div class="px-3 py-2 rounded-lg bg-[#141414] border border-white/10 flex items-center gap-2">
              <Icon name="check" class="w-3.5 h-3.5 text-[#FF5A2D]" />
              <span data-i18n="picking.mock.wz" class="text-white/70 text-xs font-medium tracking-wide">{t.mock.wz}</span>
            </div>
          </div>

          <div class="relative rounded-[36px] bg-gradient-to-b from-[#222] to-[#0e0e0e] border border-white/10 p-3 shadow-[0_30px_80px_-20px_rgba(0,0,0,0.8)]">
            <div class="flex items-center justify-between px-4 pt-1 pb-3">
              <span class="text-[10px] text-white/30 tracking-[0.25em] uppercase">TeamBear</span>
              <div class="flex items-center gap-1">
                <span class="w-1 h-1 rounded-full bg-white/30"></span>
                <span class="w-6 h-1 rounded-full bg-white/15"></span>
              </div>
            </div>

            <div class="relative rounded-[20px] bg-[#0a0a0a] overflow-hidden border border-white/[0.06]">
              <div class="flex items-center justify-between px-4 py-2 text-[10px] text-white/40 border-b border-white/5">
                <span>09:24</span>
                <div class="flex items-center gap-2">
                  <span>Wi-Fi</span>
                  <span>87%</span>
                </div>
              </div>

              <div class="px-4 pt-4 pb-3">
                <div class="flex items-center justify-between mb-3">
                  <span data-i18n="picking.mock.order" class="text-[10px] text-[#FF5A2D] tracking-[0.2em] uppercase font-medium">{t.mock.order}</span>
                  <span class="text-[10px] text-white/30">3 / 7</span>
                </div>
                <div class="text-white text-lg font-semibold leading-tight">#ZK-2034</div>
                <div data-i18n="picking.mock.customer" class="text-white/40 text-xs mt-1">{t.mock.customer}</div>
              </div>

              <div class="mx-3 mb-2 rounded-xl bg-[#FF5A2D]/10 border border-[#FF5A2D]/30 p-3">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <div>
                    <div data-i18n="picking.mock.loc" class="text-[9px] text-[#FF5A2D] uppercase tracking-[0.2em] font-medium">{t.mock.loc}</div>
                    <div data-i18n="picking.mock.product" class="text-white text-sm font-semibold mt-1">{t.mock.product}</div>
                  </div>
                  <div class="shrink-0 w-8 h-8 rounded-md bg-[#FF5A2D] flex items-center justify-center">
                    <Icon name="scanLine" class="w-4 h-4 text-white" strokeWidth={2.4} />
                  </div>
                </div>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <span data-i18n="picking.mock.qty" class="text-white/60 text-[10px]">{t.mock.qty}</span>
                    <span class="px-2 py-0.5 rounded bg-white/10 text-white text-xs font-semibold">2 / 2</span>
                  </div>
                  <Icon name="barcode" class="w-10 h-4 text-white/40" strokeWidth={1.6} />
                </div>
              </div>

              <div class="mx-3 mb-2 rounded-xl bg-white/[0.02] border border-white/5 p-3 flex items-center justify-between">
                <div>
                  <div class="text-[9px] text-white/30 uppercase tracking-[0.2em]">B · 12</div>
                  <div data-i18n="picking.mock.done1" class="text-white/50 text-xs font-medium line-through mt-0.5">{t.mock.done1}</div>
                </div>
                <div class="w-6 h-6 rounded-full bg-white/5 flex items-center justify-center">
                  <Icon name="check" class="w-3.5 h-3.5 text-white/50" strokeWidth={2.4} />
                </div>
              </div>

              <div class="mx-3 mb-3 rounded-xl bg-white/[0.02] border border-white/5 p-3 flex items-center justify-between">
                <div>
                  <div class="text-[9px] text-white/30 uppercase tracking-[0.2em]">C · 04</div>
                  <div data-i18n="picking.mock.done2" class="text-white/50 text-xs font-medium line-through mt-0.5">{t.mock.done2}</div>
                </div>
                <div class="w-6 h-6 rounded-full bg-white/5 flex items-center justify-center">
                  <Icon name="check" class="w-3.5 h-3.5 text-white/50" strokeWidth={2.4} />
                </div>
              </div>

              <div class="mx-3 mb-3 px-3 py-2 rounded-lg bg-white/[0.03] border border-white/5 flex items-center justify-between">
                <span data-i18n="picking.mock.path" class="text-[10px] text-white/40 uppercase tracking-[0.15em]">{t.mock.path}</span>
                <div class="flex items-center gap-1">
                  <span class="text-[10px] text-white/50">C</span>
                  <Icon name="arrowRight" class="w-2.5 h-2.5 text-white/30" />
                  <span class="text-[10px] text-white/50">B</span>
                  <Icon name="arrowRight" class="w-2.5 h-2.5 text-white/30" />
                  <span class="text-[10px] text-[#FF5A2D] font-semibold">A</span>
                  <Icon name="arrowRight" class="w-2.5 h-2.5 text-white/30" />
                  <span class="text-[10px] text-white/30">D</span>
                  <Icon name="arrowRight" class="w-2.5 h-2.5 text-white/30" />
                  <span class="text-[10px] text-white/30">F</span>
                </div>
              </div>

              <div class="px-3 pb-4">
                <div data-i18n="picking.mock.finish" class="w-full py-3 rounded-xl bg-[#FF5A2D] text-white text-xs font-semibold text-center tracking-wide">
                  {t.mock.finish}
                </div>
              </div>

              <div class="flex items-center justify-center pb-2">
                <span class="w-16 h-1 rounded-full bg-white/15"></span>
              </div>
            </div>

            <div class="flex items-center justify-center gap-3 pt-3 pb-1">
              <span class="w-12 h-1.5 rounded-full bg-white/10"></span>
              <span class="w-3 h-3 rounded-full border border-white/15"></span>
            </div>
          </div>

          <div class="absolute top-1/2 -translate-y-1/2 -right-2 w-1.5 h-16 rounded-full bg-white/5"></div>
          <div class="absolute top-1/3 -left-2 w-1.5 h-10 rounded-full bg-white/5"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 border-t border-white/5 bg-[#1a1a1a]/80 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-4 flex flex-wrap items-center justify-center md:justify-between gap-4 text-center md:text-left">
      {
        t.trust.map((item, i) => (
          <>
            {i > 0 && <span class="text-white/20 text-xs hidden md:inline">·</span>}
            <span data-i18n={`picking.trust.${i}`} class="text-white/30 text-xs tracking-[0.2em] uppercase">{item}</span>
          </>
        ))
      }
    </div>
  </div>
</section>
