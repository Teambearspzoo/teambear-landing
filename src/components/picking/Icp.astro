---
import Icon from '../Icon.astro';
import { content } from '../../i18n';

const t = content.pl.picking;
---

<!-- SEKCJA 07: DLA KOGO -->
<section class="bg-[#141414] py-32 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
    <div class="reveal max-w-3xl mb-16">
      <span data-i18n="picking.icp.eyebrow" class="block text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-4">{t.icp.eyebrow}</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
        <span data-i18n="picking.icp.title1">{t.icp.title1}</span><br /><span data-i18n="picking.icp.title2" class="text-white/40">{t.icp.title2}</span>
      </h2>
      <p data-i18n="picking.icp.lead" class="text-white/50 text-lg">{t.icp.lead}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="reveal p-8 md:p-10 rounded-2xl bg-[#FF5A2D]/[0.04] border border-[#FF5A2D]/20">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-lg bg-[#FF5A2D]/15 flex items-center justify-center">
            <Icon name="check" class="w-5 h-5 text-[#FF5A2D]" strokeWidth={2.4} />
          </div>
          <h3 data-i18n="picking.icp.forTitle" class="text-xl font-semibold text-white">{t.icp.forTitle}</h3>
        </div>
        <ul class="space-y-4">
          {
            t.icp.for.map((line, i) => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 mt-1 w-5 h-5 rounded-full bg-[#FF5A2D]/15 flex items-center justify-center">
                  <Icon name="check" class="w-3 h-3 text-[#FF5A2D]" strokeWidth={2.6} />
                </span>
                <span data-i18n={`picking.icp.for.${i}`} class="text-white/75 leading-relaxed">{line}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="reveal p-8 md:p-10 rounded-2xl bg-white/[0.02] border border-white/5" style="transition-delay:120ms">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
            <Icon name="x" class="w-5 h-5 text-white/60" strokeWidth={2.4} />
          </div>
          <h3 data-i18n="picking.icp.notTitle" class="text-xl font-semibold text-white/80">{t.icp.notTitle}</h3>
        </div>
        <ul class="space-y-4">
          {
            t.icp.not.map((line, i) => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 mt-1 w-5 h-5 rounded-full bg-white/5 flex items-center justify-center">
                  <Icon name="x" class="w-3 h-3 text-white/40" strokeWidth={2.6} />
                </span>
                <span data-i18n={`picking.icp.not.${i}`} class="text-white/50 leading-relaxed">{line}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
