---
import Icon from '../Icon.astro';
import { content } from '../../i18n';

const t = content.pl.picking;
const offerIcons = ['smartphone', 'monitor', 'scanLine', 'plug'];
---

<!-- SEKCJA 03: CO DOSTAJESZ -->
<section id="co-dostajesz" class="bg-[#141414] py-32 relative overflow-hidden scroll-mt-[136px]">
  <div class="absolute top-0 right-1/4 w-[min(500px,100vw)] h-[min(500px,100vw)] bg-[#FF5A2D]/5 rounded-full blur-[150px] pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
    <div class="reveal max-w-3xl mb-16">
      <span data-i18n="picking.offer.eyebrow" class="block text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-4">{t.offer.eyebrow}</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
        <span data-i18n="picking.offer.title1">{t.offer.title1}</span><br /><span data-i18n="picking.offer.title2" class="text-white/40">{t.offer.title2}</span>
      </h2>
      <p data-i18n="picking.offer.lead" class="text-white/50 text-lg leading-relaxed">
        {t.offer.lead}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {
        t.offer.items.map((o, i) => (
          <div class="reveal group p-8 md:p-10 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[#FF5A2D]/20 hover:bg-white/[0.04] transition-all duration-500" style={`transition-delay:${i * 80}ms`}>
            <div class="flex items-center justify-between mb-8">
              <div class="w-14 h-14 rounded-xl bg-[#FF5A2D]/10 flex items-center justify-center group-hover:bg-[#FF5A2D]/20 transition-colors duration-300">
                <Icon name={offerIcons[i]} class="w-6 h-6 text-[#FF5A2D]" />
              </div>
              <span data-i18n={`picking.offer.items.${i}.label`} class="px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-white/40 bg-white/5 rounded-full border border-white/10">{o.label}</span>
            </div>
            <h3 data-i18n={`picking.offer.items.${i}.title`} class="text-2xl font-semibold text-white mb-4 group-hover:text-[#FF5A2D] transition-colors duration-300">{o.title}</h3>
            <p data-i18n={`picking.offer.items.${i}.body`} class="text-white/50 leading-relaxed">{o.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
