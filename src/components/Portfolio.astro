---
import { content } from '../i18n';
import { projects as projectMeta } from '../projects';
const t = content.pl.portfolio;

const projects = t.projects.map((p, i) => ({ ...projectMeta[i], ...p }));
---

<section id="portfolio" class="bg-[#141414] py-32 relative overflow-hidden">
  <div class="absolute top-1/3 left-1/4 w-[min(600px,100vw)] h-[min(600px,100vw)] bg-[#FF5A2D]/5 rounded-full blur-[150px] pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
    <div class="reveal text-center mb-20">
      <span class="text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-4 block">//04</span>
      <h2 data-i18n="portfolio.heading" class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">{t.heading}</h2>
      <p data-i18n="portfolio.lead" class="text-white/50 text-lg max-w-2xl mx-auto">{t.lead}</p>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      {
        projects.map((p, i) => (
          <div class="reveal group">
            <a href={`/portfolio/${p.slug}`} class="block h-full">
              <div class="h-full rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[#FF5A2D]/20 hover:bg-white/[0.04] transition-all duration-500 overflow-hidden">
                <div class="relative h-64 overflow-hidden bg-gradient-to-br from-[#FF5A2D]/10 to-[#FF5A2D]/5">
                  <img
                    src={p.image}
                    alt={p.title}
                    class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-[#141414] via-transparent to-transparent" />
                </div>
                <div class="p-8">
                  <div class="mb-4">
                    <span data-i18n="portfolio.category" class="text-[#FF5A2D]/60 text-xs uppercase tracking-widest">{t.category}</span>
                  </div>
                  <h3 data-i18n={`portfolio.projects.${i}.title`} class="text-2xl font-semibold text-white mb-4 group-hover:text-[#FF5A2D] transition-colors duration-300">{p.title}</h3>
                  <p data-i18n={`portfolio.projects.${i}.desc`} class="text-white/50 leading-relaxed mb-6">{p.desc}</p>
                  <div class="flex flex-wrap gap-2">
                    {p.tags.map((tag) => (
                      <span class="px-3 py-1 text-xs font-medium text-white/40 bg-white/5 rounded-full border border-white/10">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
