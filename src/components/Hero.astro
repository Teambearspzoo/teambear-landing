---
import { content } from '../i18n';
const t = content.pl.hero;
---

<section class="relative min-h-screen flex items-center justify-center bg-[#1a1a1a] overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image:linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px);background-size:60px 60px"
  >
  </div>
  <div class="absolute top-1/4 right-1/4 w-[min(600px,100vw)] h-[min(600px,100vw)] bg-[#FF5A2D]/10 rounded-full blur-[150px] pointer-events-none">
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20">
    <div class="max-w-4xl">
      <div class="reveal">
        <span data-i18n="hero.eyebrow" class="inline-block text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-6">{t.eyebrow}</span>
      </div>
      <h1 class="reveal text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] tracking-tight mb-8">
        <span data-i18n="hero.title1">{t.title1}</span><br />
        <span data-i18n="hero.title2" class="text-white/40">{t.title2}</span>
      </h1>
      <p data-i18n="hero.lead" class="reveal text-lg md:text-xl text-white/60 max-w-2xl mb-12 leading-relaxed">
        {t.lead}
      </p>
      <div class="reveal flex flex-col sm:flex-row gap-4">
        <a href="#kontakt" data-i18n="hero.cta1" class="inline-flex items-center justify-center px-8 py-4 bg-[#FF5A2D] text-white font-medium rounded-lg hover:bg-[#FF5A2D]/90 transition-all duration-300 hover:translate-y-[-2px]">{t.cta1}</a>
        <a href="#uslugi" data-i18n="hero.cta2" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-lg hover:bg-white/5 transition-all duration-300">{t.cta2}</a>
      </div>
    </div>
    <div class="reveal absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex">
      <div class="flex flex-col items-center gap-2">
        <span data-i18n="hero.scroll" class="text-white/30 text-xs tracking-widest uppercase">{t.scroll}</span>
        <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
      </div>
    </div>
  </div>
</section>
