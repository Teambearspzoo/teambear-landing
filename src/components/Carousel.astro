---
interface Props {
  images?: string[];
  alt: string;
}
const { images = [], alt } = Astro.props;
const multiple = images.length > 1;
---

<div class="relative rounded-2xl overflow-hidden border border-white/5 bg-[#141414]" data-carousel>
  <div class="flex transition-transform duration-500 ease-out" data-carousel-track>
    {
      images.map((src, i) => (
        <div class="w-full shrink-0">
          <img
            src={src}
            alt={`${alt} - ${i + 1}`}
            loading={i === 0 ? 'eager' : 'lazy'}
            class="w-full aspect-video object-contain"
          />
        </div>
      ))
    }
  </div>

  {
    multiple && (
      <>
        <button
          type="button"
          data-carousel-prev
          aria-label="Previous image"
          class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/50 hover:bg-[#FF5A2D] text-white flex items-center justify-center backdrop-blur-sm transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
            <path d="m15 18-6-6 6-6" />
          </svg>
        </button>
        <button
          type="button"
          data-carousel-next
          aria-label="Next image"
          class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/50 hover:bg-[#FF5A2D] text-white flex items-center justify-center backdrop-blur-sm transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </button>
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2" data-carousel-dots>
          {images.map((_, i) => (
            <button
              type="button"
              data-carousel-dot
              aria-label={`Go to image ${i + 1}`}
              class="w-2 h-2 rounded-full transition-all duration-300"
            />
          ))}
        </div>
      </>
    )
  }
</div>

<script>
  function initCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>('[data-carousel-track]');
    if (!track) return;
    const slides = track.children.length;
    if (slides <= 1) return;

    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-carousel-dot]'));
    let index = 0;

    const render = () => {
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, i) => {
        const active = i === index;
        dot.className =
          'rounded-full transition-all duration-300 ' +
          (active ? 'w-6 h-2 bg-[#FF5A2D]' : 'w-2 h-2 bg-white/40 hover:bg-white/70');
      });
    };

    const go = (next: number) => {
      index = (next + slides) % slides;
      render();
    };

    root.querySelector('[data-carousel-prev]')?.addEventListener('click', () => go(index - 1));
    root.querySelector('[data-carousel-next]')?.addEventListener('click', () => go(index + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));

    root.tabIndex = 0;
    root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') go(index - 1);
      if (e.key === 'ArrowRight') go(index + 1);
    });

    render();
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
</script>
