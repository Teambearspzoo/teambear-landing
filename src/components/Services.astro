---
import { content } from '../i18n';
const t = content.pl.services;

const icons = ['code', 'lightbulb', 'zap', 'link'];
const services = t.items.map((item, i) => ({
  n: String(i + 1).padStart(2, '0'),
  icon: icons[i],
  ...item,
}));
---

<section id="uslugi" class="bg-[#1a1a1a] py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-12 gap-16 lg:gap-24">
      <div class="lg:col-span-4">
        <div class="reveal">
          <span class="text-[#FF5A2D] text-sm font-medium tracking-[0.2em] uppercase mb-4 block">//02</span>
          <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
            <span data-i18n="services.heading1">{t.heading1}</span><br /><span data-i18n="services.heading2">{t.heading2}</span>
          </h2>
        </div>
      </div>
      <div class="lg:col-span-8">
        <div class="space-y-0">
          {
            services.map((s, i) => (
              <div class="reveal group border-t border-white/10 py-10 first:border-t-0 first:pt-0">
                <div class="flex items-start gap-6">
                  <span class="text-white/20 text-sm font-medium mt-1">{s.n}</span>
                  <div class="flex-1">
                    <div class="flex items-center gap-4 mb-4">
                      <div class="w-10 h-10 rounded-lg bg-[#FF5A2D]/10 flex items-center justify-center group-hover:bg-[#FF5A2D]/20 transition-colors duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[#FF5A2D]" aria-hidden="true">
                          {s.icon === 'code' && (
                            <>
                              <path d="m18 16 4-4-4-4" />
                              <path d="m6 8-4 4 4 4" />
                              <path d="m14.5 4-5 16" />
                            </>
                          )}
                          {s.icon === 'lightbulb' && (
                            <>
                              <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
                              <path d="M9 18h6" />
                              <path d="M10 22h4" />
                            </>
                          )}
                          {s.icon === 'zap' && (
                            <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" />
                          )}
                          {s.icon === 'link' && (
                            <>
                              <path d="M9 17H7A5 5 0 0 1 7 7h2" />
                              <path d="M15 7h2a5 5 0 1 1 0 10h-2" />
                              <line x1="8" x2="16" y1="12" y2="12" />
                            </>
                          )}
                        </svg>
                      </div>
                      <h3 data-i18n={`services.items.${i}.title`} class="text-xl font-semibold text-white group-hover:text-[#FF5A2D] transition-colors duration-300">{s.title}</h3>
                    </div>
                    <p data-i18n={`services.items.${i}.desc`} class="text-white/50 leading-relaxed max-w-xl">{s.desc}</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
